# Local development environment template
# Copy to .env and fill in the values — NEVER commit .env

# Postgres (docker-compose local)
POSTGRES_USER=admin
POSTGRES_PASSWORD=       # Set a strong password locally
POSTGRES_DB=gym_management

# App
DATABASE_URL="postgresql://admin:<password>@localhost:5432/gym_management?schema=public"
TRAINER_USER_ID=         # UUID of trainer user — run: SELECT id FROM "User" LIMIT 1;

# Google Cloud Storage — avatar uploads
GCP_PROJECT_ID=
GCP_CLIENT_EMAIL=
GCP_PRIVATE_KEY=""
GCS_BUCKET_NAME=
