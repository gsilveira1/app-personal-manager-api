generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum ClientStatus {
  Active
  Inactive
  Lead
}

// --- Models ---

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user") // 'admin', 'trainer'
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamentos: O usuário é dono de tudo isso
  clients            Client[]
  sessions           Session[]
  recurringEvents    RecurringEvent[]
  plans              Plan[]
  workoutPlans       WorkoutPlan[]
  settings           UserSetting[]
  availabilityBlocks AvailabilityBlock[]
}

model Client {
  id             String       @id @default(uuid())
  name           String
  email          String       @unique
  phone          String
  status         ClientStatus @default(Active)
  type           String
  goal           String?
  avatar         String?
  notes          String?
  dateOfBirth    DateTime?
  checkInFreq    String?
  medicalHistory Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamento com Plano
  planId String?
  plan   Plan?   @relation(fields: [planId], references: [id])

  // Relacionamento com Usuário (Dono do registro)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Outros relacionamentos
  sessions        Session[]
  recurringEvents RecurringEvent[]
  workouts        WorkoutPlan[]
  evaluations     Evaluation[]

  @@index([userId])
  @@index([status])
}

model Plan {
  id              String   @id @default(uuid())
  type            String // 'PRESENCIAL' | 'CONSULTORIA'
  name            String // e.g., "Hipertrofia 2x na Semana (60min)"
  sessionsPerWeek Int // 1–6 for PRESENCIAL, 1–2 for CONSULTORIA
  durationMinutes Int? // 30, 45, 60, 90 (null for CONSULTORIA)
  price           Float
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  // Planos pertencem a um Usuário (Treinador)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  clients  Client[]
  features PlanFeature[]
}

model SystemFeature {
  id          String   @id @default(uuid())
  key         String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plans PlanFeature[]
}

model PlanFeature {
  planId     String
  featureId  String
  assignedAt DateTime      @default(now())
  plan       Plan          @relation(fields: [planId], references: [id], onDelete: Cascade)
  feature    SystemFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)

  @@id([planId, featureId])
  @@index([featureId])
}

model Session {
  id              String   @id @default(uuid())
  date            DateTime
  durationMinutes Int
  type            String
  category        String
  completed       Boolean  @default(false)
  notes           String?
  recurrenceId    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relacionamento com Cliente (Quem treinou)
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  // Relacionamento com Usuário (Responsável pela sessão/Treinador)
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Relacionamento com Treino
  linkedWorkoutId String?
  workout         WorkoutPlan? @relation(fields: [linkedWorkoutId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@index([clientId])
}

model WorkoutPlan {
  id          String   @id @default(uuid())
  title       String
  description String?
  status      String   @default("Active")
  tags        String[]
  exercises   Json[]

  // Treinos pertencem a um Usuário (Treinador) - Obrigatório
  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Treinos podem pertencer a um Cliente (Opcional - se for null, é um Template)
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id])

  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([clientId])
}

model Evaluation {
  id                String   @id @default(uuid())
  date              DateTime
  weight            Float
  height            Float?
  bodyFatPercentage Float?
  leanMass          Float?
  notes             String?
  perimeters        Json?
  skinfolds         Json?

  // Avaliações pertencem a um Cliente
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([clientId])
}

// Configurações específicas por Usuário
model UserSetting {
  key   String
  value String

  userId String
  user   User   @relation(fields: [userId], references: [id])

  // Chave composta: cada usuário pode ter sua própria chave 'ai_prompt', por exemplo.
  @@id([userId, key])
}

// ---
// RFC 5545-based recurrence (Google Calendar model)
// ---

model RecurringEvent {
  id              String   @id @default(uuid())
  /// Full RRULE string, e.g. "FREQ=WEEKLY;BYDAY=MO,WE;COUNT=12"
  rrule           String
  /// TZID used when expanding the rule, e.g. "America/Sao_Paulo"
  timezone        String   @default("America/Sao_Paulo")
  /// ISO datetime of the first occurrence (DTSTART)
  dtstart         DateTime
  durationMinutes Int
  type            String // "In-Person" | "Online"
  category        String // "Workout" | "Check-in" | "Evaluation"
  notes           String?
  linkedWorkoutId String?

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId   String
  user     User   @relation(fields: [userId], references: [id])

  exceptions SessionException[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([clientId])
}

model SessionException {
  id String @id @default(uuid())

  /// The computed start time this exception replaces
  originalStartTime DateTime

  /// true = this occurrence is cancelled (soft-delete)
  cancelled Boolean @default(false)

  /// Overrides (only relevant when cancelled = false)
  newStartTime    DateTime?
  durationMinutes Int?
  notes           String?
  completed       Boolean   @default(false)

  recurringEventId String
  recurringEvent   RecurringEvent @relation(fields: [recurringEventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([recurringEventId, originalStartTime])
  @@index([recurringEventId])
}

model AvailabilityBlock {
  id       String   @id @default(uuid())
  title    String                         // "Almoço", "Férias"
  rrule    String?                        // null = one-off, else RFC 5545
  timezone String   @default("America/Sao_Paulo")
  dtstart  DateTime
  dtend    DateTime                       // dtstart+dtend define the block window
  notes    String?

  userId   String
  user     User     @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, dtstart])
}
